<h1>Student List</h1>

<table border="1" cellpadding="10">
    <tr>
        <th>Name</th>
        <th>Department</th>
        <th>Email</th>
        <th>Action</th>
    </tr>

    @foreach (var student in Model)
    {
        <tr>
            <td>@student.Name</td>
            <td>@student.Department</td>
            <td>@student.Email</td>
            <td>
                <a href="/Student/Delete/@student.Email">Delete</a> <a href="/Student/Edit?id=@student.Email">Edit</a>
            </td>
        </tr>
    }
</table>

<br />

<a href="/Student/Create">Add New Student</a>